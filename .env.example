GRAYLOG_URL=https://graylog.example.com
GRAYLOG_TOKEN=your_graylog_token
GRAYLOG_TIMEZONE=America/Chicago
GRAYLOG_SEARCH_LIMIT=1000

# Either use a relative window or explicit hours.
# Default is the last 24 hours.
REPORT_WINDOW_HOURS=24

# Optional Graylog stream IDs, comma separated.
GRAYLOG_STREAM_IDS=

# Optional Zabbix API enrichment.
ZABBIX_ENABLED=false
ZABBIX_URL=https://zabbix.example.com
ZABBIX_API_TOKEN=your_zabbix_api_token
ZABBIX_PROBLEM_LIMIT=200

OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4.1-mini
# Optional. Used for GPT-5/o-series reasoning models. Good default for this digest: minimal.
OPENAI_REASONING_EFFORT=minimal

SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

REPORT_TITLE=Daily Network Syslog Summary

# Local event memory used to identify new, recurring, and chronic unchanged issues.
REPORT_HISTORY_ENABLED=true
REPORT_HISTORY_DAYS=30
REPORT_HISTORY_PATH=.data/report-history.jsonl

# When true, skips Graylog and uses sample network syslog events.
MOCK_MODE=false
